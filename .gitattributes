# Handle line endings automatically for files detected as text 
# and leave binary files untouched.
* text=auto

# Force LF for all C/C++ source and header files
*.cpp text eol=lf
*.hpp text eol=lf
*.c text eol=lf
*.h text eol=lf

# Force LF for configuration files
*.json text eol=lf
*.md text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.clangd text eol=lf
.clang-format text eol=lf
